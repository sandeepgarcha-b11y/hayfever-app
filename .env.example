# Copy this file to .env.local and fill in the values.

# Google Maps Platform API key
# Required. Enable both the "Weather API" and "Pollen API" on your GCP project.
# https://console.cloud.google.com/apis/library
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Upstash Redis — for IP rate limiting on /api/conditions
# Optional. Get free credentials at https://upstash.com (no credit card required).
# If left blank, rate limiting is disabled.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
